# PDF AI Highlighter – API keys (copy to .env and fill in)

# For OpenAI (ChatGPT): get key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# OpenAI model (optional). Default: gpt-4o. Examples: gpt-4o-mini, gpt-4o
# OPENAI_MODEL=gpt-4o
# OPENAI_MODEL=gpt-5.2-2025-12-11

# For Hugging Face: get token from https://huggingface.co/settings/tokens (scope: Inference API)
HUGGINGFACE_TOKEN=hf_...

# Highlight colors (optional). Use either "r,g,b" (0–1) or hex "#RRGGBB".
# Default color for all highlights (when not using --category-colors):
# PDF_HIGHLIGHT_COLOR=1,1,0
# PDF_HIGHLIGHT_COLOR=#FFFF00

# When using --category-colors, per-category colors:
# PDF_HIGHLIGHT_COLOR_BULLET=0.85,0.85,0.75
# PDF_HIGHLIGHT_COLOR_IMPORTANT=1,1,0
# PDF_HIGHLIGHT_COLOR_NOVELTY=0.6,1,0.6
